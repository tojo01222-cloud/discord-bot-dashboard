# Discord Bot Token (NIEMALS in Code oder Chat teilen!)
DISCORD_TOKEN=

# Standard-Bot-Sprache: de oder en (kann pro Server im Dashboard überschrieben werden)
DEFAULT_LANGUAGE=de

# Datenbank
# Fuer lokales Testen reicht SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./bot_database.db
# Fuer den echten Betrieb (Bot und Dashboard auf getrennten Anbietern) wird eine
# ueber das Netzwerk erreichbare Datenbank gebraucht, z.B. eine kostenlose Neon.tech
# Postgres-Datenbank. Format (OHNE "?sslmode=require" am Ende -- das SSL wird vom
# Code automatisch aktiviert, siehe bot/database/db.py):
#   DATABASE_URL=postgresql+asyncpg://user:passwort@ep-xxxxx.region.aws.neon.tech/dbname
DATABASE_URL=sqlite+aiosqlite:///./bot_database.db

# Discord Application (für OAuth im Web-Dashboard)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Muss exakt der URL entsprechen, die im Discord Developer Portal unter
# OAuth2 -> Redirects eingetragen ist. Bei Render.com bekommst du eine kostenlose
# URL wie https://dein-app-name.onrender.com -- dann hier:
# https://dein-app-name.onrender.com/auth/callback
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# Dashboard: zufälliger, langer Zeichen-String zum Signieren der Login-Sessions
# (z.B. mit: python3 -c "import secrets; print(secrets.token_urlsafe(32))" erzeugen)
SESSION_SECRET=

# Bot-Owner (Discord User-ID) — hat immer vollen Zugriff, unabhängig von Server-Rollen
BOT_OWNER_ID=
